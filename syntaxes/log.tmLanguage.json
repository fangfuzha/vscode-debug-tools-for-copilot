{
  "scopeName": "text.log",
  "patterns": [
    {
      "name": "log.error",
      "match": "\\[ERROR\\]"
    },
    {
      "name": "log.warning",
      "match": "\\[WARN\\]"
    },
    {
      "name": "log.info",
      "match": "\\[INFO\\]"
    },
    {
      "name": "log.debug",
      "match": "\\[DEBUG\\]"
    },
    {
      "name": "comment log.date",
      "match": "\\[\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}\\.\\d{3}\\]"
    }
  ]
}
