{
  "name": "vscode-debug-tools-for-copilot",
  "displayName": "%displayName%",
  "version": "0.1.3",
  "description": "%description%",
  "publisher": "fangfuzha",
  "repository": {
    "type": "git",
    "url": "https://github.com/fangfuzha/vscode-debug-tools-for-copilot.git"
  },
  "license": "MIT",
  "keywords": [
    "调试",
    "debug",
    "Copilot",
    "agent"
  ],
  "engines": {
    "vscode": "^1.115.0"
  },
  "l10n": "./l10n",
  "activationEvents": [
    "onDebug",
    "onStartupFinished"
  ],
  "categories": [
    "AI",
    "Chat",
    "Debuggers"
  ],
  "icon": "icon.png",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "debugtools.add-mcp-to-agent",
        "title": "%debugtools.add-mcp-to-agent%",
        "category": "%VS Code Debug Tools%"
      },
      {
        "command": "debugtools.show-mcp-diagnostics",
        "title": "%debugtools.show-mcp-diagnostics%",
        "category": "%VS Code Debug Tools%"
      },
      {
        "command": "debugtools.export-mcp-configuration",
        "title": "%debugtools.export-mcp-configuration%",
        "category": "%VS Code Debug Tools%"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "debugtools.add-mcp-to-agent",
          "when": "true"
        },
        {
          "command": "debugtools.show-mcp-diagnostics",
          "when": "true"
        },
        {
          "command": "debugtools.export-mcp-configuration",
          "when": "true"
        }
      ]
    },
    "chatSkills": [
      {
        "path": "./src/lm/skills/breakpoint-mcp-tools-guide/SKILL.md"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "fangfuzha.vscode-debug-tools-for-copilot",
        "label": "%mcp.breakpointProvider.label%"
      }
    ],
    "languages": [
      {
        "id": "log",
        "aliases": [
          "Log",
          "log"
        ],
        "extensions": [
          ".log"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "log",
        "scopeName": "text.log",
        "path": "./syntaxes/log.tmLanguage.json"
      }
    ],
    "colors": [
      {
        "id": "log.error",
        "description": "Color for error log level",
        "defaults": {
          "dark": "#f48771",
          "light": "#e45649",
          "highContrast": "#f48771"
        }
      },
      {
        "id": "log.warning",
        "description": "Color for warning log level",
        "defaults": {
          "dark": "#cca700",
          "light": "#e2c08d",
          "highContrast": "#cca700"
        }
      },
      {
        "id": "log.info",
        "description": "Color for info log level",
        "defaults": {
          "dark": "#3794ff",
          "light": "#0e70c0",
          "highContrast": "#3794ff"
        }
      },
      {
        "id": "log.debug",
        "description": "Color for debug log level",
        "defaults": {
          "dark": "#6a9955",
          "light": "#098658",
          "highContrast": "#6a9955"
        }
      }
    ]
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/node": "^2.0.0-alpha.2",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "zod": "^4.3.6"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --target=node20 --outfile=out/extension.js --external:vscode --minify",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "package": "npm run bundle && npx @vscode/vsce package"
  },
  "devDependencies": {
    "esbuild": "^0.19.4",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.6",
    "@types/vscode": "^1.115.0",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "@vscode/test-electron": "^2.4.6",
    "eslint": "^8.56.0",
    "typescript": "5.3.2"
  }
}
