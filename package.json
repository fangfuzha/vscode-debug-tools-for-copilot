{
  "name": "vscode-debug-tools-for-copilot",
  "displayName": "%displayName%",
  "version": "0.1.1",
  "description": "%description%",
  "publisher": "fangfuzha",
  "repository": {
    "type": "git",
    "url": "https://github.com/fangfuzha/vscode-debug-tools-for-copilot.git"
  },
  "license": "MIT",
  "keywords": [
    "调试",
    "debug",
    "Copilot",
    "agent"
  ],
  "engines": {
    "vscode": "^1.115.0"
  },
  "l10n": "./l10n",
  "activationEvents": [
    "onDebug",
    "onStartupFinished"
  ],
  "categories": [
    "AI",
    "Chat",
    "Debuggers"
  ],
  "icon": "icon.png",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "debugtools.configureAgentConfigurations",
        "title": "%Configure AI Agent MCP%",
        "category": "%VS Code Debug Tools%"
      }
    ],
    "chatSkills": [
      {
        "path": "./src/lm/skills/breakpoint-mcp-tools-guide/SKILL.md"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "fangfuzha.vscode-debug-tools-for-copilot",
        "label": "%mcp.breakpointProvider.label%"
      }
    ]
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/node": "^2.0.0-alpha.2",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "zod": "^4.3.6"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.6",
    "@types/vscode": "^1.115.0",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "@vscode/test-electron": "^2.4.6",
    "eslint": "^8.56.0",
    "typescript": "5.3.2"
  }
}
