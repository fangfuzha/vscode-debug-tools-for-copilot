{
  // 编译器选项配置，用于指定 TypeScript 编译器的行为
  "compilerOptions": {
    // 指定编译后的 JavaScript 代码所遵循的 ECMAScript 版本
    "target": "ES2020",
    // 指定生成的模块代码的模块系统规范
    "module": "Node16",
    // 启用所有严格类型检查选项，增强代码的类型安全性
    "strict": true,
    // 支持 ES6 模块和 CommonJS 模块之间的互操作性
    "esModuleInterop": true,
    // 让 TypeScript 正确解析 ESM-only 依赖提供的 .d.mts 声明文件
    "moduleResolution": "Node16",
    // 跳过对所有声明文件（.d.ts）的类型检查，提高编译速度
    "skipLibCheck": true,
    // 允许导入 .json 文件并将其作为模块使用
    "resolveJsonModule": true,
    "outDir": "./out", // 编译输出目录
    "rootDir": "./src", // 源代码根目录
    "types": [
      "node"
    ]
  },
  "sourceMap": true, // 生成 source map 文件，方便调试
  // 指定需要编译的文件或文件模式
  "include": [
    "src/**/*.ts"
  ],
  // 指定需要排除在编译过程之外的文件或目录
  "exclude": [
    "node_modules",
    "out"
  ]
}